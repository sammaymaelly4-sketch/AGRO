{
  "rewrites": [
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/clientes", "destination": "/clientes.html" },
    { "source": "/produtos", "destination": "/produtos.html" },
    { "source": "/vendas", "destination": "/vendas.html" },
    { "source": "/estoque", "destination": "/estoque.html" },
    { "source": "/financeiro", "destination": "/financeiro.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
